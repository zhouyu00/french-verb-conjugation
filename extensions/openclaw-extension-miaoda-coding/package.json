{
  "name": "@lark-apaas/openclaw-extension-miaoda-coding",
  "version": "1.0.8",
  "description": "妙搭 Coding Agent — 通过 AI 创建和修改妙搭应用",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "build:dev": "MINIFY=false tsdown",
    "test": "vitest run",
    "test:cov": "vitest --coverage",
    "ci": "npm run test"
