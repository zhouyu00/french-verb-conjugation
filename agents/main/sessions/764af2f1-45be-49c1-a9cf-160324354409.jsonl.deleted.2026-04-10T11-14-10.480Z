jugation","target":"user:ou_2458d9c0becde3ce8d02a3cc32a281de"}}],"api":"openai-completions","provider":"miaoda","model":"miaoda-model-auto","usage":{"input":1765,"output":585,"cacheRead":30011,"cacheWrite":0,"totalTokens":32361,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775816039989}}
